<?xml version="1.0"?>
<!-- Minimal 1-DOF turntable + 3R arm for Motus planning-group demos.
     Tip path: turntable → shoulder → elbow → wrist (4 actuated joints).
     No external meshes — box/cylinder primitives only. -->
<robot name="turntable_arm">
  <link name="base_link">
    <visual>
      <origin xyz="0 0 0.02" rpy="0 0 0"/>
      <geometry><cylinder length="0.04" radius="0.22"/></geometry>
      <material name="base_grey"><color rgba="0.45 0.45 0.48 1"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 0.02" rpy="0 0 0"/>
      <geometry><cylinder length="0.04" radius="0.22"/></geometry>
    </collision>
  </link>

  <link name="turntable_link">
    <visual>
      <origin xyz="0 0 0.03" rpy="0 0 0"/>
      <geometry><cylinder length="0.06" radius="0.18"/></geometry>
      <material name="turntable"><color rgba="0.2 0.55 0.45 1"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 0.03" rpy="0 0 0"/>
      <geometry><cylinder length="0.06" radius="0.18"/></geometry>
    </collision>
  </link>

  <link name="shoulder_link">
    <visual>
      <origin xyz="0 0 0.08" rpy="0 0 0"/>
      <geometry><cylinder length="0.16" radius="0.05"/></geometry>
      <material name="arm"><color rgba="0.75 0.75 0.78 1"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 0.08" rpy="0 0 0"/>
      <geometry><cylinder length="0.16" radius="0.05"/></geometry>
    </collision>
  </link>

  <link name="elbow_link">
    <visual>
      <origin xyz="0.15 0 0" rpy="0 1.5708 0"/>
      <geometry><cylinder length="0.30" radius="0.04"/></geometry>
      <material name="arm"/>
    </visual>
    <collision>
      <origin xyz="0.15 0 0" rpy="0 1.5708 0"/>
      <geometry><cylinder length="0.30" radius="0.04"/></geometry>
    </collision>
  </link>

  <link name="wrist_link">
    <visual>
      <origin xyz="0.12 0 0" rpy="0 1.5708 0"/>
      <geometry><cylinder length="0.24" radius="0.035"/></geometry>
      <material name="arm"/>
    </visual>
    <collision>
      <origin xyz="0.12 0 0" rpy="0 1.5708 0"/>
      <geometry><cylinder length="0.24" radius="0.035"/></geometry>
    </collision>
  </link>

  <link name="tool0">
    <visual>
      <origin xyz="0 0 0.02" rpy="0 0 0"/>
      <geometry><box size="0.04 0.04 0.04"/></geometry>
      <material name="tip"><color rgba="0.9 0.35 0.2 1"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 0.02" rpy="0 0 0"/>
      <geometry><box size="0.04 0.04 0.04"/></geometry>
    </collision>
  </link>

  <!-- External axis: Z-up rotary table under the arm. -->
  <joint name="turntable" type="revolute">
    <parent link="base_link"/>
    <child link="turntable_link"/>
    <origin xyz="0 0 0.04" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.14159" upper="3.14159" velocity="1.5"/>
  </joint>

  <joint name="shoulder" type="revolute">
    <parent link="turntable_link"/>
    <child link="shoulder_link"/>
    <origin xyz="0 0 0.06" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.14159" upper="3.14159" velocity="2.0"/>
  </joint>

  <joint name="elbow" type="revolute">
    <parent link="shoulder_link"/>
    <child link="elbow_link"/>
    <origin xyz="0 0 0.16" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-2.5" upper="2.5" velocity="2.0"/>
  </joint>

  <joint name="wrist" type="revolute">
    <parent link="elbow_link"/>
    <child link="wrist_link"/>
    <origin xyz="0.30 0 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-2.5" upper="2.5" velocity="2.0"/>
  </joint>

  <joint name="flange" type="fixed">
    <parent link="wrist_link"/>
    <child link="tool0"/>
    <origin xyz="0.24 0 0" rpy="0 0 0"/>
  </joint>
</robot>
