<Project>
  <PropertyGroup>
    <_MotusCoreDll>$(MotusNetRoot)src\Motus.Core\bin\$(MotusNetConfiguration)\net8.0\Motus.Core.dll</_MotusCoreDll>
    <_MotusGeometryDll>$(MotusNetRoot)src\Motus.Geometry\bin\$(MotusNetConfiguration)\net8.0\Motus.Geometry.dll</_MotusGeometryDll>
    <_MotusPresetsDll>$(MotusNetRoot)src\Motus.Presets\bin\$(MotusNetConfiguration)\net8.0\Motus.Presets.dll</_MotusPresetsDll>
    <_MotusOmplDll>$(MotusNetRoot)src\Motus.OMPL.NET\bin\$(MotusNetConfiguration)\net8.0\Motus.OMPL.NET.dll</_MotusOmplDll>
    <_MotusNetVersionFile>$(MotusNetRoot)motus-net.version</_MotusNetVersionFile>
    <MotusNetRequiredVersion Condition="'$(MotusNetRequiredVersion)' == ''">0.3.0</MotusNetRequiredVersion>
  </PropertyGroup>

  <Target Name="VerifyMotusNetVersion" BeforeTargets="EnsureMotusNetDlls">
    <Error Condition="!Exists('$(_MotusNetVersionFile)')"
           Text="Missing $(_MotusNetVersionFile). Build Motus.NET at $(MotusNetRoot) first." />
    <ReadLinesFromFile File="$(_MotusNetVersionFile)">
      <Output TaskParameter="Lines" ItemName="_MotusNetVersionLines" />
    </ReadLinesFromFile>
    <PropertyGroup>
      <_MotusNetBuiltVersion>@(_MotusNetVersionLines)</_MotusNetBuiltVersion>
    </PropertyGroup>
    <Error Condition="'$(_MotusNetBuiltVersion)' != '$(MotusNetRequiredVersion)'"
           Text="Motus.NET version mismatch: sibling repo is $(_MotusNetBuiltVersion) but Motus.Grasshopper requires $(MotusNetRequiredVersion). Rebuild Motus.NET or update MotusNetRequiredVersion in build/MotusNetDll.targets." />
  </Target>

  <Target Name="EnsureMotusNetDlls" BeforeTargets="ResolveAssemblyReferences">
    <Error Condition="!Exists('$(_MotusCoreDll)')"
           Text="Motus.Core.dll not found at $(_MotusCoreDll). Build Motus.NET: dotnet build $(MotusNetRoot)Motus.NET.slnx -c $(MotusNetConfiguration)" />
    <Error Condition="'$(MSBuildProjectName)' != 'Motus.Core' and !Exists('$(_MotusGeometryDll)')"
           Text="Motus.Geometry.dll not found. Build Motus.NET first." />
  </Target>

  <ItemGroup Condition="'$(MSBuildProjectName)' == 'Motus.Rhino' or '$(MSBuildProjectName)' == 'Motus.GH'">
    <Reference Include="Motus.Core">
      <HintPath>$(_MotusCoreDll)</HintPath>
      <Private>true</Private>
    </Reference>
    <Reference Include="Motus.Geometry">
      <HintPath>$(_MotusGeometryDll)</HintPath>
      <Private>true</Private>
    </Reference>
  </ItemGroup>

  <ItemGroup Condition="'$(MSBuildProjectName)' == 'Motus.GH'">
    <Reference Include="Motus.Presets">
      <HintPath>$(_MotusPresetsDll)</HintPath>
      <Private>true</Private>
    </Reference>
    <Reference Include="Motus.OMPL.NET">
      <HintPath>$(_MotusOmplDll)</HintPath>
      <Private>true</Private>
    </Reference>
  </ItemGroup>
</Project>
