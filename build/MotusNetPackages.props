<Project>
  <PropertyGroup>
    <MotusNetVersion Condition="'$(MotusNetVersion)' == ''">0.6.2</MotusNetVersion>
  </PropertyGroup>

  <ItemGroup Condition="'$(UseMotusNetProjectReference)' != 'true' and '$(MSBuildProjectName)' == 'Motus.GH'">
    <PackageReference Include="Motus.Core" Version="$(MotusNetVersion)" />
    <PackageReference Include="Motus.Geometry" Version="$(MotusNetVersion)" />
    <PackageReference Include="Motus.Presets" Version="$(MotusNetVersion)" />
    <PackageReference Include="Motus.OMPL.NET" Version="$(MotusNetVersion)" />
  </ItemGroup>

  <ItemGroup Condition="'$(UseMotusNetProjectReference)' != 'true' and '$(MSBuildProjectName)' == 'QaSmoke'">
    <PackageReference Include="Motus.Core" Version="$(MotusNetVersion)" />
    <PackageReference Include="Motus.Geometry" Version="$(MotusNetVersion)" />
    <PackageReference Include="Motus.Presets" Version="$(MotusNetVersion)" />
    <PackageReference Include="Motus.OMPL.NET" Version="$(MotusNetVersion)" />
  </ItemGroup>
</Project>
