<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net8.0-windows</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <Version>0.6.1</Version>
    <AssemblyVersion>0.6.1.0</AssemblyVersion>
    <FileVersion>0.6.1.0</FileVersion>
    <InformationalVersion>0.6.1</InformationalVersion>
    <TargetExt>.gha</TargetExt>
    <EnableDynamicLoading>true</EnableDynamicLoading>
    <UseWindowsForms>true</UseWindowsForms>
    <CopyLocalLockFileAssemblies>true</CopyLocalLockFileAssemblies>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\Motus.Rhino\Motus.Rhino.csproj" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="RhinoCommon" Version="8.32.26160.13001" />
    <Reference Include="Grasshopper">
      <HintPath>$(Rhino8Dir)\Plug-ins\Grasshopper\Grasshopper.dll</HintPath>
      <Private>false</Private>
    </Reference>
    <Reference Include="GH_IO">
      <HintPath>$(Rhino8Dir)\Plug-ins\Grasshopper\GH_IO.dll</HintPath>
      <Private>false</Private>
    </Reference>
  </ItemGroup>

  <ItemGroup>
    <EmbeddedResource Include="Resources\icons\*.png" />
    <None Include="..\..\resources\viewer_presets.json" Link="resources\viewer_presets.json">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
    <None Include="..\..\resources\tools\robotiq_2f85_tcp_local.stl" Link="resources\tools\robotiq_2f85_tcp_local.stl">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
  </ItemGroup>

  <PropertyGroup>
    <GrasshopperLibraryDir>$([System.Environment]::GetFolderPath(SpecialFolder.ApplicationData))\Grasshopper\Libraries\Motus</GrasshopperLibraryDir>
  </PropertyGroup>

  <Target Name="CopyGhaToGrasshopperLibraries" AfterTargets="Build" Condition="'$(OS)' == 'Windows_NT'">
    <MakeDir Directories="$(GrasshopperLibraryDir)" />
    <ItemGroup>
      <MotusDeployFiles Include="$(TargetDir)Motus*.gha" />
      <MotusDeployFiles Include="$(TargetDir)Motus*.dll" />
      <MotusDeployFiles Include="$(MotusNetSiblingRoot)src\Motus.Native\bin\$(Configuration)\net8.0\Motus.Native.dll" Condition="Exists('$(MotusNetSiblingRoot)src\Motus.Native\bin\$(Configuration)\net8.0\Motus.Native.dll')" />
      <MotusDeployFiles Include="$(TargetDir)resources\**\*" />
    </ItemGroup>
    <Copy
      SourceFiles="@(MotusDeployFiles)"
      DestinationFiles="@(MotusDeployFiles->'$(GrasshopperLibraryDir)\%(RecursiveDir)%(Filename)%(Extension)')"
      SkipUnchangedFiles="true"
      Retries="3"
      RetryDelayMilliseconds="500"
      ContinueOnError="WarnAndContinue" />
  </Target>

</Project>
